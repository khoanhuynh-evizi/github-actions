                          "url": "${GSHEET_URL}"
                        }
                      }
                    }
                  ]
                }
              },
              {
                "textParagraph": {
                  "text": "${PLATFORM_TEXT}<br><br>🌿 <b>Branch auto:</b> <code>${BRANCH_WDIO}</code><br>🌿 <b>Branch code:</b> <code>${BRANCH_DASHBOARD}</code>"
                }
              }
            ]
          }
        ]
      }
    }
  ]
}
