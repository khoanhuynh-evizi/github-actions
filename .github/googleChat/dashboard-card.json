{
  "cardsV2": [
    {
      "cardId": "wdio-report",
      "card": {
        "header": {
          "title": "${STATUS_ICON} Record360 - Dashboard Automation Report",
          "subtitle": "Smoke Test · ${DATE_TIME}"
        },
        "sections": [
          {
            "widgets": [
              {
                "buttonList": {
                  "buttons": [
                    {
                      "text": "📄 VIEW ALLURE REPORT",
                      "onClick": {
                        "openLink": {
                          "url": "${REPORT_URL}"
                        }
                      }
                    }
                  ]
                }
              },
              {
                  "textParagraph": { "text": "📊 <b>Test Summary</b>" }
              },
              {
                "textParagraph": {
                  "text": "✅ <b>Passed:</b> ${PASSED} (${PASS_RATE}%)<br>❌ <b>Failed:</b> ${FAILED}<br>⏭️ <b>Skipped:</b> ${SKIPPED}<br>🔁 <b>Retries:</b> ${RETRIES}<br>📦 <b>Total:</b> ${TOTAL}<br>⏱️ <b>Duration:</b> ${DURATION}<br>🌿 <b>Branch:</b> <code>ai-smart-review</code><br><b>Status:</b> <font color=\"${STATUS_COLOR}\"><b>${STATUS}</b></font>"
                }
              }
            ]
          }      
        ]
      }
    }
  ]
}
